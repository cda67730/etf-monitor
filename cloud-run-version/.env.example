# Cloud Run 環境變數範例 (含安全設定)

# 基本設定
ENVIRONMENT=production
DEBUG=false
PORT=8080

# 域名設定
ALLOWED_HOSTS=your-service-name-hash-as.a.run.app,your-domain.com

# 資料庫設定
DATABASE_URL=sqlite:///etf_holdings.db

# Cloud Scheduler 安全令牌
SCHEDULER_TOKEN=your-random-secret-token-123

# 網頁訪問密碼 (重要：請修改為強密碼)
WEB_PASSWORD=etf2024

# 會話管理
SESSION_SECRET=your-session-secret-key-here
SESSION_TIMEOUT=28800

# 流量限制設定
RATE_LIMIT_REQUESTS=100
API_DAILY_LIMIT=1000

# Google Cloud 項目設定
GOOGLE_CLOUD_PROJECT=your-project-id

# 安全建議:
# 1. WEB_PASSWORD 請使用強密碼，至少12位字符
# 2. SCHEDULER_TOKEN 請使用隨機生成的長字符串
# 3. SESSION_SECRET 請使用隨機生成的密鑰
# 4. 生產環境請將 DEBUG 設為 false